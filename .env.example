# カーナベル Elasticsearch 接続情報
KANABELL_CLOUD_ID=ecommerce-prod:XXXXXXXXXX
KANABELL_API_KEY=XXXXXXXXXX
KANABELL_INDEX=ec-cards

# ヘルスチェック認証キー（任意）
HEALTH_CHECK_KEY=

# Discord Webhook URL（監視通知用、任意）
DISCORD_WEBHOOK_URL=

# 一人回し(solo play) kill-switch。0 で一人回しのみ停止（コア機能は無傷）。未設定/1 で有効。
ENABLE_VISUAL_SOLO_PLAY=1

# Flask設定
FLASK_DEBUG=0
PORT=5000
